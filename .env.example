# Copy this file to .env and fill in real values. .env is gitignored.

# Autius account credentials
AUTIUS_USERNAME=your-autius-email@example.com
AUTIUS_PASSWORD=your-autius-password

# Discord webhook that receives "new slot available" notifications
AUTIUS_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxxxxxxxxxxxx/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override browser automation paths (defaults target a Raspberry Pi / Debian image)
CHROMEDRIVER_PATH=/home/pi/chromedriver
CHROMIUM_BINARY_PATH=/usr/bin/chromium-browser
